{
  "name": "@lmnr-ai/claude-code-proxy",
  "version": "0.1.16",
  "description": "HTTP proxy for Claude Desktop API requests with Laminar observability",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "napi": {
    "binaryName": "lmnr-claude-code-proxy",
    "package": {
      "name": "@lmnr-ai/claude-code-proxy"
    },
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl"
    ]
  },
  "files": [
    "dist"
  ],
  "optionalDependencies": {
    "@lmnr-ai/claude-code-proxy-darwin-arm64": "0.1.16",
    "@lmnr-ai/claude-code-proxy-darwin-x64": "0.1.16",
    "@lmnr-ai/claude-code-proxy-win32-x64-msvc": "0.1.16",
    "@lmnr-ai/claude-code-proxy-linux-x64-gnu": "0.1.16",
    "@lmnr-ai/claude-code-proxy-linux-arm64-gnu": "0.1.16",
    "@lmnr-ai/claude-code-proxy-linux-x64-musl": "0.1.16",
    "@lmnr-ai/claude-code-proxy-linux-arm64-musl": "0.1.16"
  },
  "keywords": [
    "claude",
    "proxy",
    "anthropic",
    "laminar",
    "observability",
    "napi"
  ],
  "author": "Laminar AI",
  "license": "MIT",
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {},
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build:cargo": "cd ../bin && cargo build --release --features typescript",
    "build:napi": "cd ../bin && napi build --platform --release",
    "build:ts": "tsc",
    "build": "node scripts/build.js",
    "test": "echo \"Error: no test specified\" && exit 0",
    "napi": "napi",
    "universalize": "napi universalize"
  }
}